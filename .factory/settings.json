{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [{
          "type": "command",
          "command": "python3 /srv/bmad-tlg/scripts/hooks/session_register.py",
          "timeout": 10
        }]
      }
    ],
    "Notification": [
      {
        "hooks": [{
          "type": "command",
          "command": "python3 /srv/bmad-tlg/scripts/hooks/notification_hook.py",
          "timeout": 360
        }]
      }
    ],
    "Stop": [
      {
        "hooks": [{
          "type": "command",
          "command": "python3 /srv/bmad-tlg/scripts/hooks/task_complete.py",
          "timeout": 15
        }]
      }
    ]
  }
}
