# ========================================
# MiniChess Bot Configuration
# ========================================
# 
# This file contains configuration for the chess.com bot.
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env:
#    cp .env.example .env
# 
# 2. Edit .env and replace the placeholder values below
# 
# 3. NEVER commit .env to git (it's in .gitignore)
#
# ========================================

# Chess.com account credentials
# Used for logging into chess.com to play minihouse games
CHESS_COM_EMAIL=your-email@gmail.com
CHESS_COM_PASSWORD=your-password-here

# Optional: Uncomment to enable debug mode
# DEBUG=true
